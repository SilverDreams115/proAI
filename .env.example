PROAI_APP_NAME=proAI
PROAI_APP_VERSION=0.1.0
PROAI_ENVIRONMENT=production
PROAI_DATABASE_URL=postgresql+psycopg://proai:proai@postgres:5432/proai
POSTGRES_DB=proai
POSTGRES_USER=proai
POSTGRES_PASSWORD=replace-with-a-strong-db-password
PROAI_API_HOST=0.0.0.0
PROAI_API_PORT=8000
PROAI_LOG_LEVEL=INFO
PROAI_LOG_JSON=true
PROAI_ACCESS_LOG_ENABLED=true
PROAI_DOCS_ENABLED=false
PROAI_AUTH_REQUIRED=true
PROAI_AUTH_API_KEY=replace-with-a-strong-secret
PROAI_AUTH_PASSWORD_HASH=replace-with-output-from-backend-scripts-hash-password
PROAI_SESSION_SECRET=replace-with-a-random-session-secret-at-least-32-characters
PROAI_AUTH_SESSION_COOKIE_NAME=proai_session
PROAI_AUTH_SESSION_TTL_SECONDS=43200
PROAI_REQUEST_ID_HEADER=X-Request-ID
PROAI_HEALTHCHECK_TIMEOUT_SECONDS=2.0
PROAI_HEALTH_LAST_INGEST_WARNING_AGE_SECONDS=86400
PROAI_HEALTH_LAST_INGEST_CRITICAL_AGE_SECONDS=172800
PROAI_HEALTH_BACKTEST_WARNING_AGE_SECONDS=604800
PROAI_HEALTH_BACKTEST_CRITICAL_AGE_SECONDS=1209600
PROAI_HEALTH_WORKER_POLL_WARNING_AGE_SECONDS=120
PROAI_HEALTH_WORKER_POLL_CRITICAL_AGE_SECONDS=300
PROAI_ALLOWED_HOSTS=localhost,127.0.0.1
PROAI_CORS_ALLOWED_ORIGINS=
PROAI_FORCE_HTTPS=false
PROAI_ENABLE_WORKER_ROUTES=false
PROAI_ENFORCE_PRODUCTION_CONFIG=true
PROAI_WORKER_POLL_INTERVAL_SECONDS=30
PROAI_CURRENT_PROGOL_AUTO_REFRESH_ENABLED=true
PROAI_CURRENT_PROGOL_REFRESH_INTERVAL_MINUTES=60
PROAI_CURRENT_PROGOL_REFRESH_JOB_NAME=current-progol-refresh
PROAI_LIVE_RESULTS_OBSERVE_ENABLED=true
PROAI_LIVE_RESULTS_OBSERVE_INTERVAL_MINUTES=5
PROAI_LIVE_RESULTS_FETCH_ENABLED=true
PROAI_LIVE_RESULTS_SOURCE_URL=https://www.loterianacional.gob.mx/Progol/Resultados
PROAI_ALLOW_PICKLE_MODEL_ARTIFACTS=false
PROAI_LIVE_PICK_READY_COMPETITIONS=e0,premier-league
PROAI_LIVE_PICK_BLOCKED_COMPETITIONS=i1,serie-a,d1,bundesliga
PROAI_PUBLIC_HOSTNAME=localhost
PROAI_HTTP_PORT=80
PROAI_HTTPS_PORT=443
PROAI_BACKUP_INTERVAL_SECONDS=86400
PROAI_BACKUP_RETENTION_DAYS=7
PROAI_FOOTBALL_DATA_API_KEY=
PROAI_ECONOMIC_SHADOW_UNIT_COST=1.0
# Optional: payout returned by a perfect simulated line, in unit-cost units.
# Leave blank until a real prize assumption is known; blank disables ROI claims.
PROAI_ECONOMIC_SHADOW_PAYOUT_UNITS=
# API-Football (api-sports.io v3) — audit-only, OFF by default.
# The connector makes NO external call unless ENABLED=true and a key is set.
PROAI_APIFOOTBALL_ENABLED=false
PROAI_APIFOOTBALL_API_KEY=
PROAI_APIFOOTBALL_BASE_URL=

# R5.6-B controlled team rating canary (default OFF)
PROAI_TEAM_RATING_CANARY_ENABLED=false
PROAI_TEAM_RATING_CANARY_DRAW_CODES=
PROAI_TEAM_RATING_CANARY_POSITIONS=
PROAI_TEAM_RATING_CANARY_CALIBRATOR_ID=international_friendlies_temperature_v1
PROAI_TEAM_RATING_CANARY_ROUTING_POLICY=rating_replaces_fallback
PROAI_TEAM_RATING_CANARY_COMPETITION_ALLOWLIST=International Friendlies
